        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95,\n  sum by(le, job)(rate(lumio_http_request_duration_seconds_bucket[5m]))\n)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
