{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Lumio API — multi-environment view. Use the env variable to compare dev and prod side-by-side or filter to a single environment.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
