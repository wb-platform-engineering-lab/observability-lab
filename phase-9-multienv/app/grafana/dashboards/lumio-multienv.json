      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Latency Percentiles — $env",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job_env:lumio_http_request_duration_seconds:p50rate5m{job=\"lumio-api\", env=~\"$env\"}",
          "legendFormat": "P50 — {{env}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job_env:lumio_http_request_duration_seconds:p95rate5m{job=\"lumio-api\", env=~\"$env\"}",
          "legendFormat": "P95 — {{env}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job_env:lumio_http_request_duration_seconds:p99rate5m{job=\"lumio-api\", env=~\"$env\"}",
          "legendFormat": "P99 — {{env}}",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Alertmanager — Alert Routing",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Active Alerts by Environment",
      "description": "ALERTS metric — shows all currently firing alerts with their env label.\nEach line is one alert instance. Drop the env=~\"$env\" filter to see all.",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "ALERTS{job=\"lumio-api\", alertstate=\"firing\", env=~\"$env\"}",
        "legendFormat": "[{{env}}] {{alertname}} ({{severity}})",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Alertmanager Notifications Sent",
      "description": "alertmanager_notifications_total by receiver — shows that dev alerts go to dev-receiver and prod alerts go to prod-receiver.",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(alertmanager_notifications_total[5m])",
        "legendFormat": "{{receiver}} ({{integration}})",
        "refId": "A"
      }]
    }
