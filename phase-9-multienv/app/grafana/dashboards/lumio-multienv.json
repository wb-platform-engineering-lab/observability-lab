      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Rate by Environment",
      "description": "Both environments on the same panel for direct comparison.\nSelect a specific env from the variable to isolate.",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "job_env:lumio_http_requests_total:rate5m{job=\"lumio-api\", env=~\"$env\"}",
        "legendFormat": "{{env}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Rate by Endpoint — $env",
      "description": "job_env_endpoint:lumio_http_requests_total:rate5m per endpoint for the selected environment.",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "job_env_endpoint:lumio_http_requests_total:rate5m{job=\"lumio-api\", env=~\"$env\"}",
        "legendFormat": "{{env}} — {{endpoint}}",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Error Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percentunit" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "prod" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "dev" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Error Rate — dev vs prod",
      "description": "Both environments overlaid so you can immediately see when dev error rate is a false alarm vs a real prod incident.\nThe LumioHighErrorRate alert fires for both — Alertmanager routes them to the correct receiver.",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "job_env:lumio_http_requests_error_ratio:rate5m{job=\"lumio-api\", env=~\"$env\"}",
        "legendFormat": "{{env}}",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
