      "title": "P99 Latency — $env",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "job_env:lumio_http_request_duration_seconds:p99rate5m{job=\"lumio-api\", env=~\"$env\"}",
        "legendFormat": "{{env}}",
        "refId": "A"
