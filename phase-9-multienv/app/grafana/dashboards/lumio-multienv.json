      "title": "P95 Latency — dev vs prod",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job_env:lumio_http_request_duration_seconds:p95rate5m{job=\"lumio-api\", env=~\"$env\"}",
          "legendFormat": "P95 — {{env}}",
