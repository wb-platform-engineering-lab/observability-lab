  "annotations": { "list": [] },
  "description": "Lumio API — application metrics using recording rules.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Cardinality Monitor →",
