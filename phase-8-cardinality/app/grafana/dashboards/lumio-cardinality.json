{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Prometheus TSDB cardinality — series count, growth rate, memory, top metrics. Use this dashboard to detect and diagnose cardinality explosions.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "TSDB Status →",
      "url": "http://localhost:9090/tsdb-status",
      "type": "link",
      "targetBlank": true,
      "tooltip": "Prometheus built-in cardinality breakdown by metric name, label name, and label value"
    },
    {
      "title": "← Lumio API",
      "url": "/d/lumio-api",
      "type": "link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Health at a Glance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 10000 }] },
          "unit": "short", "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Active Time Series",
      "description": "prometheus_tsdb_head_series — total series in the in-memory head block.\nNormal for this lab: 200–400. Yellow > 5k, Red > 10k.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "prometheus_tsdb_head_series", "legendFormat": "series", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] },
          "unit": "short", "mappings": [],
          "decimals": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Series Growth Rate (per min)",
      "description": "rate(prometheus_tsdb_head_series[5m]) × 60.\nRed > 50/min indicates a cardinality explosion in progress.\nTriggered by CardinalityExplosion alert.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(prometheus_tsdb_head_series[5m]) * 60", "legendFormat": "new series/min", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }, { "color": "red", "value": 536870912 }] },
          "unit": "bytes", "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Prometheus RSS Memory",
      "description": "prometheus_process_resident_memory_bytes.\nCardinality explosions show as a steady climb here.\nYellow > 100 MB, Red > 512 MB.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "prometheus_process_resident_memory_bytes", "legendFormat": "RSS", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 50000 }] },
          "unit": "short", "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Head Chunks",
      "description": "prometheus_tsdb_head_chunks — number of active data chunks.\nRoughly proportional to series count × active windows.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "prometheus_tsdb_head_chunks", "legendFormat": "chunks", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Series Count Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "lineWidth": 2, "fillOpacity": 15 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Total Active Series",
      "description": "prometheus_tsdb_head_series over time.\nA cardinality explosion shows as a steep, continuous upward slope.\nA successful hotfix (labeldrop) shows as a sudden drop followed by a plateau.",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "prometheus_tsdb_head_series", "legendFormat": "total series", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Series Growth Rate (per minute)",
      "description": "rate(prometheus_tsdb_head_series[5m]) × 60.\nThe CardinalityExplosion alert fires when this exceeds 50/min for 2 minutes.\nShould be near 0 during normal operation.",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(prometheus_tsdb_head_series[5m]) * 60", "legendFormat": "new series/min", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Prometheus Memory",
      "description": "RSS grows proportionally with series count.\nAt ~1KB per series: 100k series ≈ 100 MB, 1M series ≈ 1 GB.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "prometheus_process_resident_memory_bytes", "legendFormat": "RSS (resident)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "prometheus_process_virtual_memory_bytes", "legendFormat": "virtual", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Scrape Duration",
      "description": "scrape_duration_seconds for the lumio-api job.\nAs series count grows, the /metrics response size grows too — scrape duration increases.\nThis is a secondary symptom of cardinality explosion.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "scrape_duration_seconds{job=\"lumio-api\"}", "legendFormat": "scrape duration", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Series by Metric (use TSDB Status for production)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Series Count per Job",
      "description": "count by(job)({__name__!=\"\"}) — series broken down by scrape job.\nDuring the explosion you'll see lumio-api far above all others.\nAfter the hotfix it should drop back to near the prometheus job's count.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count by(job)({__name__!=\"\"})", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Top 5 Metrics by Series Count",
      "description": "topk(5, count by(__name__)({job=\"lumio-api\"})) — which metric name has the most series?\nWarning: this query itself is expensive at high cardinality. For production use\nhttp://localhost:9090/tsdb-status instead (computed by Prometheus internally).",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(5, count by(__name__)({job=\"lumio-api\"}))", "legendFormat": "{{__name__}}", "refId": "A", "instant": false }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Scrape & Sample Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Samples Ingested per Second",
      "description": "rate(prometheus_tsdb_head_samples_appended_total[5m]) — samples written per second.\nEach time series contributes one sample per scrape_interval (15s).\nAt 1000 series: ~67 samples/sec. At 100k series: ~6700 samples/sec.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(prometheus_tsdb_head_samples_appended_total[5m])", "legendFormat": "samples/sec", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Scrape Samples per Target",
      "description": "scrape_samples_scraped — number of samples returned from each /metrics endpoint per scrape.\nGrows proportionally with series count on the app side. A good pre-ingestion signal.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "scrape_samples_scraped", "legendFormat": "{{job}} — {{instance}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["lumio", "cardinality", "prometheus", "tsdb"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Lumio — Cardinality Monitor",
  "uid": "lumio-cardinality",
  "version": 1
}
